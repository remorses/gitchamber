{
  "name": "gitchamber",
  "version": "0.1.0",
  "description": "Fetch source code for packages to give coding agents deeper context",
  "type": "module",
  "bin": "dist/cli.js",
  "files": [
    "src",
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist *.tsbuildinfo && tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "opensrc",
    "source",
    "agent",
    "cli",
    "git",
    "npm",
    "pypi",
    "crates"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remorses/gitchamber.git"
  },
  "homepage": "https://github.com/remorses/gitchamber",
  "bugs": "https://github.com/remorses/gitchamber/issues",
  "author": "remorses",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250712.0",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.15.0",
    "@xmorse/tar-parser": "^0.3.0",
    "agents": "^0.2.1",
    "marked": "^16.1.2",
    "micromatch": "^4.0.8",
    "spiceflow": "^1.17.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "wrangler": "^4.24.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6",
    "zodown": "^0.2.1"
  }
}
