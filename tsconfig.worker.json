{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "declaration": false,
    "strict": true,
    "types": ["@cloudflare/workers-types"],
    "lib": ["es2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/worker.ts",
    "src/worker.test.ts",
    "src/github-api.ts",
    "src/github-api.test.ts",
    "src/mcp-tools-schema.test.ts",
    "src/production.test.ts",
    "src/utils.ts",
    "src/types.d.ts",
    "src/mocks",
    "src/snapshots"
  ]
}
